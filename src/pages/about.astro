<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=yes">
    <meta name="referrer" content="no-referrer-when-downgrade">
    <title>About Us | 24/7 Water Damage Helpline – Public Records Research Unit</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ========== COMPLETE RESET ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            overflow-x: hidden;
            width: 100%;
            background: #ffffff;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: #1e293b;
            -webkit-font-smoothing: antialiased;
            line-height: 1.5;
        }

        /* Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            width: 100%;
        }

        /* ========== BUTTONS ========== */
        .btn {
            background: linear-gradient(135deg, #e67e22, #d35400);
            color: white;
            padding: 14px 32px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1.1rem;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
            cursor: pointer;
        }

        .btn-secondary {
            background: transparent;
            color: white;
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1rem;
            border: 2px solid white;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        /* Glass effect */
        .glass-effect {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50px;
            padding: 6px 16px;
            font-size: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        /* Grid */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 32px;
            align-items: center;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
        }

        /* Cards */
        .card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            transition: transform 0.2s ease;
        }
        .card:hover {
            transform: translateY(-5px);
        }

        .card-content {
            padding: 20px;
        }

        .card h3 {
            font-size: 1.25rem;
            margin-bottom: 8px;
            color: #0a3d62;
        }

        .card p {
            color: #4b5563;
            font-size: 0.875rem;
        }

        /* Stats */
        .stat-card {
            background: white;
            padding: 24px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border: 1px solid #e2e8f0;
        }

        .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #0a3d62, #2563eb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Section Title */
        .section-title {
            text-align: center;
            margin-bottom: 48px;
        }

        .section-title h2 {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #0a3d62, #2563eb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
        }

        .section-divider {
            width: 80px;
            height: 3px;
            background: linear-gradient(90deg, #0a3d62, #e67e22);
            margin: 16px auto;
            border-radius: 2px;
        }

        /* Value Icon Box */
        .value-box {
            text-align: center;
            padding: 28px 20px;
            background: #f8fafc;
            border-radius: 20px;
            transition: all 0.2s;
        }
        .value-box i {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #0a3d62, #e67e22);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 16px;
        }
        .value-box h3 {
            color: #0a3d62;
            margin-bottom: 8px;
        }
        .value-box p {
            color: #4b5563;
            font-size: 0.875rem;
        }

        /* Author Bio Card */
        .author-bio-card {
            background: linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
            border-radius: 32px;
            padding: 40px;
            margin: 32px 0;
            border: 1px solid #e2e8f0;
            box-shadow: 0 15px 30px rgba(0,0,0,0.05);
        }
        .author-bio-inner {
            display: flex;
            gap: 32px;
            align-items: flex-start;
            flex-wrap: wrap;
        }
        .author-image {
            flex-shrink: 0;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            border: 3px solid #e67e22;
        }
        .author-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .author-bio-content {
            flex: 1;
        }
        .author-bio-content h3 {
            font-size: 1.6rem;
            color: #0a3d62;
            margin-bottom: 8px;
        }
        .author-title {
            color: #e67e22;
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: 16px;
            letter-spacing: 0.3px;
        }
        .author-bio-text {
            color: #1e293b;
            line-height: 1.6;
            margin-bottom: 20px;
        }
        .methodology-badge {
            background: white;
            border-radius: 12px;
            padding: 16px;
            margin-top: 20px;
            font-size: 0.8rem;
            color: #475569;
            border-left: 4px solid #e67e22;
            background: #ffffffcc;
        }
        .methodology-badge i {
            color: #e67e22;
            margin-right: 8px;
        }
        .disclosure-text {
            font-size: 0.75rem;
            color: #6b7280;
            margin-top: 12px;
            border-top: 1px solid #e2e8f0;
            padding-top: 12px;
        }

        /* FAQ Item Styles */
        .faq-item {
            background: white;
            border-radius: 16px;
            margin-bottom: 16px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }

        .faq-item summary {
            padding: 20px;
            cursor: pointer;
            font-weight: 600;
            color: #0a3d62;
            display: flex;
            justify-content: space-between;
            align-items: center;
            list-style: none;
            transition: background 0.2s ease;
        }

        .faq-item summary:hover {
            background: #f8fafc;
        }

        .faq-item summary::-webkit-details-marker {
            display: none;
        }

        .faq-item summary i.fa-chevron-down {
            transition: transform 0.3s ease;
        }

        .faq-item[open] summary i.fa-chevron-down {
            transform: rotate(180deg);
        }

        .faq-item[open] summary {
            border-bottom: 1px solid #e2e8f0;
        }

        .faq-content {
            padding: 0 20px 20px 20px;
            color: #4b5563;
        }

        /* Footer */
        .footer {
            background: #0f172a;
            color: #cbd5f5;
            padding: 48px 0;
            margin-top: 48px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2rem; }
            .container { padding: 16px; }
            .author-bio-card { padding: 24px; }
            .author-image { width: 100px; height: 100px; }
            .author-bio-content h3 { font-size: 1.3rem; }
            .grid-2 { gap: 24px; }
        }

        @media (max-width: 480px) {
            .hero h1 { font-size: 1.6rem; }
            .section-title h2 { font-size: 1.6rem; }
        }

        .hero-about {
            min-height: 50vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            position: relative;
            background: #0a3d62;
        }
    </style>
</head>
